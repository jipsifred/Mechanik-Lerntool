# ── Production (Coolify / Docker) ────────────────────────
PORT=3000
NODE_ENV=production

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="CHANGE_ME_RANDOM_64_BYTE_HEX"
JWT_REFRESH_SECRET="CHANGE_ME_OTHER_RANDOM_64_BYTE_HEX"

# Optional: custom path for users database (default: server/db/users.db)
# In Docker/Coolify, set to /data/users.db for persistent volume
# USERS_DB_PATH=/data/users.db

# ── Development only ─────────────────────────────────────
# Frontend URL for CORS (only used in development, not needed in production)
# FRONTEND_URL=http://localhost:7862

# Note: GEMINI_API_KEY is NOT a server variable.
# Users enter their own key in the browser settings (stored in localStorage).
