# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this app is hosted.
APP_URL="MY_APP_URL"

# JWT secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="CHANGE_ME_RANDOM_64_BYTE_HEX"
JWT_REFRESH_SECRET="CHANGE_ME_OTHER_RANDOM_64_BYTE_HEX"

# Frontend URL for CORS (default: http://localhost:7862)
FRONTEND_URL="http://localhost:7862"
